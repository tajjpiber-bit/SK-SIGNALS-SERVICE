//@version=5
indicator("MTF BOX & Signals Terminal (1:3 RR + PnL Tracker + PK Time)", overlay=true, max_labels_count=500, max_lines_count=500, max_boxes_count=500)

// =========================================================================
// 1. INPUTS & CONFIGURATION
// =========================================================================
grp_risk = "Risk & PnL Settings (1:3 RR + Buffer)"
pip_buffer = input.float(5.0, title="SL Buffer (Pips on Wick)", minval=0.0, step=0.5, group=grp_risk)
rr_ratio   = input.float(3.0, title="Risk to Reward Ratio (1:X)", minval=1.0, step=0.5, group=grp_risk)
show_pnl_box = input.bool(true, title="Draw Visual PnL Trade Box on Chart", group=grp_risk)
show_price_labels = input.bool(true, title="Show Large Price Labels (Entry/SL/TP)", group=grp_risk)

grp_symbols = "Symbol Multi-Monitor"
sym1  = input.symbol("XAUUSD",    title="Symbol 1 - Gold", group=grp_symbols)
sym2  = input.symbol("BTCUSD",    title="Symbol 2 - Bitcoin", group=grp_symbols)
sym3  = input.symbol("NAS100USD", title="Symbol 3 - Nasdaq 100", group=grp_symbols)
sym4  = input.symbol("USDJPY",    title="Symbol 4 - USDJPY", group=grp_symbols)
sym5  = input.symbol("GBPJPY",    title="Symbol 5 - GBPJPY", group=grp_symbols)
sym6  = input.symbol("EURUSD",    title="Symbol 6 - EURUSD", group=grp_symbols)
sym7  = input.symbol("GBPUSD",    title="Symbol 7 - GBPUSD", group=grp_symbols)
sym8  = input.symbol("AUDUSD",    title="Symbol 8 - AUDUSD", group=grp_symbols)

grp_dash = "Dashboard Options"
show_tracker_table = input.bool(true, title="Show Signal Stats & PnL Tracker", group=grp_dash)
table_pos_input = input.string("top_right", title="Dashboard Position", options=["top_right", "top_left", "bottom_right", "bottom_left"], group=grp_dash)

// Position Mapping
table_pos = table_pos_input == "top_left" ? position.top_left :
             table_pos_input == "bottom_left" ? position.bottom_left :
             table_pos_input == "bottom_right" ? position.bottom_right : position.top_right

// =========================================================================
// 2. PIP VALUE CALCULATOR
// =========================================================================
f_pip_multiplier() =>
    syminfo.mintick == 0.00001 ? 0.0001 :
     syminfo.mintick == 0.001 ? 0.01 :
     syminfo.mintick == 0.01 ? 0.1 :
     syminfo.mintick == 0.1 ? 1.0 : syminfo.mintick

pip_val = f_pip_multiplier()
buffer_amount = pip_buffer * pip_val

// Timeframe String
tf_str = timeframe.isminutes ? (timeframe.multiplier >= 60 ? str.tostring(timeframe.multiplier / 60) + "H" : str.tostring(timeframe.multiplier) + "M") : 
         timeframe.isdaily ? "1D" : timeframe.period

// =========================================================================
// 3. CORE SIGNAL GENERATION ENGINE (MTF LIQUIDITY SWEEP & SWING REVERSAL)
// =========================================================================
f_calc_sweep_signals() =>
    // Higher Timeframe Zone calculation
    htf_tf = timeframe.isminutes and timeframe.multiplier <= 15 ? "240" : (timeframe.isminutes and timeframe.multiplier <= 60 ? "D" : "W")
    htf_high = request.security(syminfo.tickerid, htf_tf, high[1])
    htf_low  = request.security(syminfo.tickerid, htf_tf, low[1])

    // Sweep Logic: Candle sweeps HTF High/Low & closes back inside
    sweep_bull = (low < htf_low) and (close > htf_low) and (close > open)
    sweep_bear = (high > htf_high) and (close < htf_high) and (close < open)

    // Additional confirmation filter: Swing Reversal
    swing_low_sweep = (low < ta.lowest(low, 5)[1]) and (close > open)
    swing_high_sweep = (high > ta.highest(high, 5)[1]) and (close < open)

    buy_sig  = (sweep_bull or swing_low_sweep) and barstate.isconfirmed
    sell_sig = (sweep_bear or swing_high_sweep) and barstate.isconfirmed

    [buy_sig, sell_sig]

[is_buy_signal, is_sell_signal] = f_calc_sweep_signals()

// =========================================================================
// 4. DAILY TRACKER & PnL STATS ENGINE
// =========================================================================
var int today_signals = 0
var int today_wins = 0
var int today_losses = 0
var int active_trades = 0

// Active Trade State Variables
var string active_dir = na
var float active_entry = na
var float active_sl = na
var float active_tp = na
var int active_signal_time = na
var string active_signal_time_str = "-"

// New Day Reset (PKT / Local UTC+5)
if ta.change(time("D"))
    today_signals := 0
    today_wins := 0
    today_losses := 0

// Track Active Trade Status (Check Win / Loss)
if not na(active_dir)
    if active_dir == "BUY"
        if high >= active_tp
            today_wins := today_wins + 1
            active_trades := math.max(0, active_trades - 1)
            active_dir := na
        else if low <= active_sl
            today_losses := today_losses + 1
            active_trades := math.max(0, active_trades - 1)
            active_dir := na
    else if active_dir == "SELL"
        if low <= active_tp
            today_wins := today_wins + 1
            active_trades := math.max(0, active_trades - 1)
            active_dir := na
        else if high >= active_sl
            today_losses := today_losses + 1
            active_trades := math.max(0, active_trades - 1)
            active_dir := na

// Handle New Signals on Candle Close
var float current_entry = na
var float current_sl = na
var float current_tp = na

if is_buy_signal
    today_signals := today_signals + 1
    active_trades := 1
    active_dir := "BUY"
    current_entry := close
    current_sl := low - buffer_amount
    risk = current_entry - current_sl
    current_tp := current_entry + (risk * rr_ratio)
    active_entry := current_entry
    active_sl := current_sl
    active_tp := current_tp
    active_signal_time := time
    
    // Format PK Time (UTC+5)
    pk_h = str.tostring(hour(time, "Asia/Karachi"), "00")
    pk_m = str.tostring(minute(time, "Asia/Karachi"), "00")
    active_signal_time_str := pk_h + ":" + pk_m + " PKT"

else if is_sell_signal
    today_signals := today_signals + 1
    active_trades := 1
    active_dir := "SELL"
    current_entry := close
    current_sl := high + buffer_amount
    risk = current_sl - current_entry
    current_tp := current_entry - (risk * rr_ratio)
    active_entry := current_entry
    active_sl := current_sl
    active_tp := current_tp
    active_signal_time := time
    
    // Format PK Time (UTC+5)
    pk_h = str.tostring(hour(time, "Asia/Karachi"), "00")
    pk_m = str.tostring(minute(time, "Asia/Karachi"), "00")
    active_signal_time_str := pk_h + ":" + pk_m + " PKT"

// =========================================================================
// 5. VISUAL PnL BOX & BIG PRICE LABELS ON CHART
// =========================================================================
if is_buy_signal and show_pnl_box
    // Draw Entry, SL, TP Lines
    line.new(bar_index, current_entry, bar_index + 15, current_entry, color=color.yellow, width=2, style=line.style_dashed)
    line.new(bar_index, current_sl, bar_index + 15, current_sl, color=color.red, width=2)
    line.new(bar_index, current_tp, bar_index + 15, current_tp, color=color.green, width=2)
    
    // Fill Boxes for TP & SL
    box.new(bar_index, current_tp, bar_index + 15, current_entry, bgcolor=color.new(color.green, 85), border_color=color.green)
    box.new(bar_index, current_entry, bar_index + 15, current_sl, bgcolor=color.new(color.red, 85), border_color=color.red)

    if show_price_labels
        txt_info = "🟢 BUY SIGNAL (1:" + str.tostring(rr_ratio, "#") + " RR)\n" +
                   "🎯 ENTRY: " + str.tostring(current_entry, "#.#####") + "\n" +
                   "🛑 SL (-" + str.tostring(pip_buffer, "#.#") + " pips): " + str.tostring(current_sl, "#.#####") + "\n" +
                   "🎯 TP (1:3): " + str.tostring(current_tp, "#.#####")
        label.new(bar_index, high + (buffer_amount * 2), txt_info, color=color.rgb(16, 185, 129), textcolor=color.white, style=label.style_label_down, size=size.medium)

if is_sell_signal and show_pnl_box
    // Draw Entry, SL, TP Lines
    line.new(bar_index, current_entry, bar_index + 15, current_entry, color=color.yellow, width=2, style=line.style_dashed)
    line.new(bar_index, current_sl, bar_index + 15, current_sl, color=color.red, width=2)
    line.new(bar_index, current_tp, bar_index + 15, current_tp, color=color.green, width=2)
    
    // Fill Boxes for TP & SL
    box.new(bar_index, current_entry, bar_index + 15, current_tp, bgcolor=color.new(color.green, 85), border_color=color.green)
    box.new(bar_index, current_sl, bar_index + 15, current_entry, bgcolor=color.new(color.red, 85), border_color=color.red)

    if show_price_labels
        txt_info = "🚨 SELL SIGNAL (1:" + str.tostring(rr_ratio, "#") + " RR)\n" +
                   "🎯 ENTRY: " + str.tostring(current_entry, "#.#####") + "\n" +
                   "🛑 SL (+" + str.tostring(pip_buffer, "#.#") + " pips): " + str.tostring(current_sl, "#.#####") + "\n" +
                   "🎯 TP (1:3): " + str.tostring(current_tp, "#.#####")
        label.new(bar_index, low - (buffer_amount * 2), txt_info, color=color.red, textcolor=color.white, style=label.style_label_up, size=size.medium)

// Plot Shapes
plotshape(is_buy_signal,  title="BUY Signal Arrow",  style=shape.triangleup,   location=location.belowbar, color=color.green, size=size.large)
plotshape(is_sell_signal, title="SELL Signal Arrow", style=shape.triangledown, location=location.abovebar, color=color.red,   size=size.large)

// =========================================================================
// 6. STATS & PnL TRACKER DASHBOARD TABLE (ON CHART)
// =========================================================================
var table stats_table = table.new(table_pos, 2, 7, bgcolor=color.new(color.black, 15), border_width=1, border_color=color.gray)

if barstate.islast and show_tracker_table
    // Table Header
    table.cell(stats_table, 0, 0, "SK SIGNAL DASHBOARD", 0, 0, bgcolor=color.navy, text_color=color.white, text_size=size.normal)
    table.cell(stats_table, 1, 0, tf_str + " | PK TIME", 0, 0, bgcolor=color.navy, text_color=color.gold, text_size=size.normal)

    // Row 1: Today's Total Signals
    table.cell(stats_table, 0, 1, "📅 Today Total Signals", bgcolor=color.new(color.black, 30), text_color=color.white, text_size=size.small, text_halign=text.align_left)
    table.cell(stats_table, 1, 1, str.tostring(today_signals), bgcolor=color.new(color.black, 30), text_color=color.white, text_size=size.small)

    // Row 2: Active / Running Signals
    c_act_bg = active_trades > 0 ? (active_dir == "BUY" ? color.new(color.green, 70) : color.new(color.red, 70)) : color.new(color.black, 30)
    act_status_text = active_trades > 0 ? active_dir + " (Running)" : "None"
    table.cell(stats_table, 0, 2, "⚡ Active Signals Now", bgcolor=c_act_bg, text_color=color.white, text_size=size.small, text_halign=text.align_left)
    table.cell(stats_table, 1, 2, act_status_text, bgcolor=c_act_bg, text_color=color.white, text_size=size.small)

    // Row 3: Wins / Losses Count Today
    win_loss_text = "🟢 " + str.tostring(today_wins) + " Win  |  🔴 " + str.tostring(today_losses) + " Loss"
    table.cell(stats_table, 0, 3, "🏆 Today Win / Loss", bgcolor=color.new(color.black, 30), text_color=color.white, text_size=size.small, text_halign=text.align_left)
    table.cell(stats_table, 1, 3, win_loss_text, bgcolor=color.new(color.black, 30), text_color=color.white, text_size=size.small)

    // Row 4: Last Signal Time (PK Time)
    table.cell(stats_table, 0, 4, "⏰ Last Signal Time", bgcolor=color.new(color.black, 30), text_color=color.white, text_size=size.small, text_halign=text.align_left)
    table.cell(stats_table, 1, 4, active_signal_time_str, bgcolor=color.new(color.black, 30), text_color=color.gold, text_size=size.small)

    // Row 5: Risk Reward Ratio & SL Buffer
    table.cell(stats_table, 0, 5, "🎯 Strategy RR / Buffer", bgcolor=color.new(color.black, 30), text_color=color.white, text_size=size.small, text_halign=text.align_left)
    table.cell(stats_table, 1, 5, "1:3 RR (" + str.tostring(pip_buffer, "#.#") + " Pips SL)", bgcolor=color.new(color.black, 30), text_color=color.white, text_size=size.small)

// =========================================================================
// 7. ALERTS (WITH SL, TP, PnL & PK TIME)
// =========================================================================
if is_buy_signal
    msg = "🟢 SK SIGNAL (BUY)\n" +
          "Pair: " + syminfo.ticker + " (" + tf_str + ")\n" +
          "Entry: " + str.tostring(current_entry, "#.#####") + "\n" +
          "SL (5 Pips Buffer): " + str.tostring(current_sl, "#.#####") + "\n" +
          "TP (1:3 RR): " + str.tostring(current_tp, "#.#####") + "\n" +
          "Time: " + active_signal_time_str
    alert(msg, alert.freq_once_per_bar_close)

if is_sell_signal
    msg = "🚨 SK SIGNAL (SELL)\n" +
          "Pair: " + syminfo.ticker + " (" + tf_str + ")\n" +
          "Entry: " + str.tostring(current_entry, "#.#####") + "\n" +
          "SL (5 Pips Buffer): " + str.tostring(current_sl, "#.#####") + "\n" +
          "TP (1:3 RR): " + str.tostring(current_tp, "#.#####") + "\n" +
          "Time: " + active_signal_time_str
    alert(msg, alert.freq_once_per_bar_close)
